{
  "datasets": [
    {
      "name": "summary",
      "displayName": "Trip Summary",
      "queryLines": [
        "SELECT COUNT(*) AS total_trips, ROUND(AVG(fare_amount), 2) AS avg_fare, ROUND(AVG(trip_distance), 2) AS avg_distance, ROUND(SUM(fare_amount), 2) AS total_revenue FROM samples.nyctaxi.trips"
      ]
    },
    {
      "name": "daily_trips",
      "displayName": "Daily Trips",
      "queryLines": [
        "SELECT DATE_TRUNC('DAY', tpep_pickup_datetime) AS trip_date, COUNT(*) AS trip_count, ROUND(SUM(fare_amount), 2) AS daily_revenue, ROUND(AVG(fare_amount), 2) AS avg_fare FROM samples.nyctaxi.trips GROUP BY DATE_TRUNC('DAY', tpep_pickup_datetime) ORDER BY trip_date"
      ]
    },
    {
      "name": "hourly",
      "displayName": "Hourly Distribution",
      "queryLines": [
        "SELECT HOUR(tpep_pickup_datetime) AS pickup_hour, COUNT(*) AS trip_count, ROUND(AVG(fare_amount), 2) AS avg_fare FROM samples.nyctaxi.trips GROUP BY HOUR(tpep_pickup_datetime) ORDER BY pickup_hour"
      ]
    },
    {
      "name": "top_pickups",
      "displayName": "Top Pickup Zones",
      "queryLines": [
        "SELECT CAST(pickup_zip AS STRING) AS pickup_zip, COUNT(*) AS trip_count, ROUND(AVG(fare_amount), 2) AS avg_fare, ROUND(AVG(trip_distance), 2) AS avg_distance FROM samples.nyctaxi.trips GROUP BY pickup_zip ORDER BY trip_count DESC LIMIT 10"
      ]
    },
    {
      "name": "distance_buckets",
      "displayName": "Distance Buckets",
      "queryLines": [
        "SELECT CASE WHEN trip_distance < 1 THEN '0-1 mi' WHEN trip_distance < 3 THEN '1-3 mi' WHEN trip_distance < 5 THEN '3-5 mi' WHEN trip_distance < 10 THEN '5-10 mi' ELSE '10+ mi' END AS distance_bucket, COUNT(*) AS trip_count, ROUND(AVG(fare_amount), 2) AS avg_fare FROM samples.nyctaxi.trips GROUP BY distance_bucket ORDER BY avg_fare"
      ]
    },
    {
      "name": "day_of_week",
      "displayName": "Day of Week",
      "queryLines": [
        "SELECT DATE_FORMAT(tpep_pickup_datetime, 'EEEE') AS day_of_week, DAYOFWEEK(tpep_pickup_datetime) AS day_num, COUNT(*) AS trip_count, ROUND(AVG(fare_amount), 2) AS avg_fare, ROUND(SUM(fare_amount), 2) AS total_revenue FROM samples.nyctaxi.trips GROUP BY day_of_week, day_num ORDER BY day_num"
      ]
    }
  ],
